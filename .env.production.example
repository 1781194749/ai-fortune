# 玄机 AI 生产环境变量模板
# 复制为 .env.production.local 或部署平台环境变量后，替换所有 <...> 占位值。

# 基础域名与主体
APP_URL="https://xuanji.click"
APP_LOCALE="zh-CN"
COMPANY_NAME="<company-or-individual-business-name>"
ICP_RECORD_NO="京ICP备2026044070号"
AUTH_SESSION_SECRET="<64-character-random-secret>"

# 后台访问保护
ADMIN_DASHBOARD_ENABLED="true"
ADMIN_ACCESS_TOKEN="<64-character-random-admin-token>"

# PostgreSQL
DATABASE_URL="<postgresql-connection-string>"
# 生产默认禁止数据库故障时回退到进程内存；除非紧急演示，不要改成 true。
ALLOW_UNSAFE_PRODUCTION_DATABASE_FALLBACK="false"

# Redis / 深度报告队列
REDIS_URL="redis://redis:6379"
DEEP_REPORT_QUEUE_ATTEMPTS="5"
DEEP_REPORT_WORKER_CONCURRENCY="2"
DEEP_REPORT_DISPATCH_INTERVAL_MS="30000"

# OpenAI
OPENAI_API_KEY="<openai-api-key>"
OPENAI_DEFAULT_MODEL="gpt-5.4-mini"
OPENAI_FAST_MODEL="gpt-5.4-nano"
OPENAI_PREMIUM_MODEL="gpt-5.5"
OPENAI_VISION_MODEL="<vision-capable-model>"
OPENAI_MODERATION_ENABLED="true"
XUANJI_PROMPT_RELEASE_ID="xuanji-prompt-2026-07-16.2"
XUANJI_PROMPT_STABLE_RELEASE_ID="xuanji-prompt-2026-07-16-stable"
XUANJI_PROMPT_ROLLOUT_PERCENT="100"
XUANJI_PROMPT_ROLLED_BACK="false"
OPENAI_DEFAULT_INPUT_CENTS_PER_1M_TOKENS="<cny-cents-per-1m-input-tokens>"
OPENAI_DEFAULT_OUTPUT_CENTS_PER_1M_TOKENS="<cny-cents-per-1m-output-tokens>"

# 登录
AUTH_EMAIL_ENABLED="false"
AUTH_GOOGLE_ENABLED="true"
GOOGLE_CLIENT_ID="<google-oauth-client-id>"
GOOGLE_CLIENT_SECRET="<google-oauth-client-secret>"
AUTH_WECHAT_ENABLED="false"
WECHAT_APP_ID="<wechat-open-platform-app-id>"
WECHAT_APP_SECRET="<wechat-open-platform-app-secret>"

# 支付
PAYMENT_PROVIDER="live"
LIVE_PAYMENT_SMOKE_TEST_USER_IDS="<comma-separated-internal-test-user-ids>"
LIVE_PAYMENT_SMOKE_TEST_EMAILS="<comma-separated-internal-test-emails>"
PAYMENT_CALLBACK_DEV_BYPASS="false"

# 支付宝
ALIPAY_ENABLED="true"
ALIPAY_GATEWAY="https://openapi.alipay.com/gateway.do"
ALIPAY_APP_ID="<alipay-app-id>"
ALIPAY_PRIVATE_KEY="<alipay-application-private-key>"
ALIPAY_PUBLIC_KEY="<alipay-public-key>"

# 微信支付
WECHAT_PAY_ENABLED="true"
WECHAT_PAY_MCH_ID="<wechat-pay-merchant-id>"
WECHAT_PAY_API_V3_KEY="<wechat-pay-api-v3-key>"
WECHAT_PAY_PRIVATE_KEY="<wechat-pay-merchant-private-key>"
WECHAT_PAY_SERIAL_NO="<wechat-pay-merchant-serial-no>"
WECHAT_PAY_PLATFORM_PUBLIC_KEY="<wechat-pay-platform-public-key>"

# 七牛云
QINIU_ACCESS_KEY="<qiniu-access-key>"
QINIU_SECRET_KEY="<qiniu-secret-key>"
QINIU_BUCKET="ai-fortune"
QINIU_REGION=""
# www.xuanji.click already CNAMEs to www-xuanji-click-idvrsqm.qiniudns.com.
# Bind an SSL certificate in Qiniu before using this HTTPS value in production.
QINIU_PUBLIC_DOMAIN="https://www.xuanji.click"
