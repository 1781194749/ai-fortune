{
  "name": "ai-fortune",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build && npm run build:worker",
    "build:worker": "node scripts/build-deep-report-worker.mjs",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --incremental false",
    "infra:up": "docker compose up -d postgres redis",
    "infra:down": "docker compose down",
    "infra:status": "docker compose ps",
    "infra:logs": "docker compose logs -f postgres redis",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose stop postgres",
    "db:status": "docker compose ps postgres",
    "db:logs": "docker compose logs -f postgres",
    "redis:up": "docker compose up -d redis",
    "redis:down": "docker compose stop redis",
    "redis:status": "docker compose ps redis",
    "redis:logs": "docker compose logs -f redis",
    "prod:tunnel": "bash scripts/tunnel-production-data.sh",
    "launch:secrets": "node scripts/launch-secrets.mjs",
    "launch:db-check": "node scripts/launch-db-check.mjs",
    "launch:url-check": "node scripts/launch-url-check.mjs",
    "launch:ai-storage-check": "node scripts/launch-ai-storage-check.mjs",
    "launch:payment-check": "node scripts/launch-payment-check.mjs",
    "launch:qualification-check": "node scripts/launch-qualification-check.mjs",
    "launch:compliance-check": "node scripts/launch-compliance-check.mjs",
    "launch:production-gate": "node scripts/launch-production-gate.mjs",
    "launch:core-gate": "node scripts/launch-production-gate.mjs --defer-live-payment --defer-qiniu",
    "launch:production-gate:example": "node scripts/launch-production-gate.mjs --env .env.production.example --skip-network --no-fail",
    "launch:production-gate-check": "node scripts/launch-production-gate-check.mjs",
    "launch:purchase-intent-check": "node scripts/launch-purchase-intent-check.mjs",
    "launch:member-entitlements-check": "node scripts/launch-member-entitlements-check.mjs",
    "membership:lifecycle-check": "node scripts/membership-lifecycle-check.mjs",
    "launch:ai-chat-process-check": "node scripts/launch-ai-chat-process-check.mjs",
    "chat:quality-check": "node scripts/chat-quality-check.mjs",
    "chat:quality-gate": "CHAT_QUALITY_REQUIRE_MODEL=1 CHAT_QUALITY_MODEL_CHECK=1 node scripts/chat-quality-check.mjs",
    "launch:goal-followup-check": "node scripts/launch-goal-followup-check.mjs",
    "launch:offline-action-check": "node scripts/launch-offline-action-check.mjs",
    "launch:evidence-check": "node scripts/launch-evidence-check.mjs",
    "launch:daily-brief-check": "node scripts/launch-daily-brief-check.mjs",
    "launch:weekly-focus-check": "node scripts/launch-weekly-focus-check.mjs",
    "launch:goal-plan-check": "node scripts/launch-goal-plan-check.mjs",
    "launch:handoff-check": "node scripts/launch-handoff-check.mjs",
    "launch:preflight": "node scripts/launch-preflight.mjs",
    "launch:preflight:example": "node scripts/launch-preflight.mjs --env .env.production.example --no-fail",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:seed": "node scripts/seed-admin.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.11",
    "@ai-sdk/react": "^4.0.23",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/qrcode": "^1.5.6",
    "ai": "^7.0.22",
    "bullmq": "^5.80.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "lunar-typescript": "^1.8.6",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "openai": "^6.45.0",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.6.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "undici": "^8.7.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
